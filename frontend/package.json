{
  "name": "elliot-wave-analyzer-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:api": "openapi-typescript http://localhost:5001/swagger/v1/swagger.json -o src/api/generated.ts"
  },
  "dependencies": {
    "lightweight-charts": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "openapi-typescript": "^7.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  },
  "engines": {
    "node": ">=24"
  }
}
