{
  "stryker-config": {
    "project": "ElliotWaveAnalyzer.Api.csproj",
    "test-projects": ["ElliotWaveAnalyzer.Tests.csproj"],
    "reporters": ["html", "json", "markdown", "cleartext", "progress"],
    "mutation-level": "Standard",
    "thresholds": { "high": 90, "low": 75, "break": 60 },
    "ignore-mutations": ["string", "linq"],
    "mutate": [
      "**/Application/**/*.cs",
      "**/Domain/CandleWindow.cs",
      "!**/Application/AutoWaveAnalysisService.cs",
      "!**/Application/WaveAnalysisService.cs",
      "!**/Application/WaveVerificationService.cs",
      "!**/Application/TechnicalAnalysisService.cs",
      "!**/Application/TopDownAnalysisService.cs",
      "!**/Application/PortfolioReviewService.cs",
      "!**/Application/DailyReportService.cs"
    ]
  }
}
