{
  "//": "Secrets (LLM API keys, Postgres connection string, Google OAuth, SMTP/Telegram) must NOT be committed here. Set them via `dotnet user-secrets` in development or environment variables in production.",
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Auth": {
    "SessionLifetimeHours": 24,
    "CookieName": "ewa_session"
  },
  "Authentication": {
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "PostLoginRedirectUri": "http://localhost:5173"
    }
  },
  "MarketData": {
    "TwelveData": {
      "BaseUrl": "https://api.twelvedata.com/",
      "ApiKey": ""
    },
    "Yahoo": {
      "BaseUrl": "https://query1.finance.yahoo.com/"
    }
  },
  "OpenTelemetry": {
    "Endpoint": ""
  },
  "LlmProvider": {
    "Active": "Gemini",
    "TokenBudget": 0,
    "Gemini": {
      "ApiKey": "",
      "Model": "gemini-2.5-flash"
    },
    "Claude": {
      "ApiKey": "",
      "Model": "claude-opus-4-8"
    },
    "OpenAI": {
      "ApiKey": "",
      "Model": "gpt-4o-mini"
    }
  },
  "DailyReport": {
    "Enabled": false,
    "Cron": "0 8 * * *",
    "Symbols": [ "BTC", "ETH" ],
    "Days": 90,
    "Telegram": {
      "Enabled": false,
      "BotToken": "",
      "ChatId": ""
    },
    "Email": {
      "Enabled": false,
      "Host": "",
      "Port": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "From": "",
      "To": []
    }
  },
  "Alerts": {
    "Enabled": false,
    "Cron": "0 * * * *",
    "ChartDays": 90
  },
  "PortfolioReview": {
    "Enabled": false,
    "Cron": "0 6 * * *"
  },
  "HealthMonitor": {
    "Enabled": false,
    "Cron": "* * * * *",
    "ConsecutiveFailureThreshold": 3
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
