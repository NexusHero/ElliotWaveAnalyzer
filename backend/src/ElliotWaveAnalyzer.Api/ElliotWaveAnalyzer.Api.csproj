<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>ElliotWaveAnalyzer.Api</RootNamespace>
    <AssemblyName>ElliotWaveAnalyzer.Api</AssemblyName>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <!-- Technical indicator calculations (RSI, MACD, EMA).
         Do NOT implement these yourself — Skender handles edge cases like
         Wilder's Smoothing for RSI and avoids precision pitfalls. -->
    <PackageReference Include="Skender.Stock.Indicators" Version="2.6.1" />

    <!-- Structured logging. Serilog over Microsoft.Extensions.Logging abstraction
         so we can swap sinks (Console → File → Seq) without code changes. -->
    <PackageReference Include="Serilog.AspNetCore" Version="9.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.0.0" />

    <!-- Built-in ASP.NET Core 10 OpenAPI support.
         Replaces Swashbuckle (not .NET 10 compatible).
         Serves OpenAPI JSON at /openapi/v1.json. -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.0" />

    <!-- Scalar: modern interactive API UI for .NET 10 built-in OpenAPI.
         Accessible at /scalar/v1 in Development.
         Replaces Swagger UI (Swashbuckle dependency). -->
    <PackageReference Include="Scalar.AspNetCore" Version="2.5.13" />

    <!-- Gemini is called via the REST API directly (HttpClient).
         No SDK dependency — avoids SDK type-surface changes between versions.
         Base URL: https://generativelanguage.googleapis.com/
         Registered in Program.cs via AddHttpClient<GeminiWaveAnalyzer>. -->
  </ItemGroup>

</Project>
