<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>ElliotWaveAnalyzer.Api</RootNamespace>
    <AssemblyName>ElliotWaveAnalyzer.Api</AssemblyName>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <!-- Technical indicator calculations (RSI, MACD, EMA).
         Do NOT implement these yourself — Skender handles edge cases like
         Wilder's Smoothing for RSI and avoids precision pitfalls. -->
    <PackageReference Include="Skender.Stock.Indicators" Version="2.6.1" />

    <!-- Structured logging. Serilog over Microsoft.Extensions.Logging abstraction
         so we can swap sinks (Console → File → Seq) without code changes. -->
    <PackageReference Include="Serilog.AspNetCore" Version="8.0.3" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.0.0" />

    <!-- OpenAPI / Swagger -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="9.0.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="7.2.0" />

    <!-- Official Google Gen AI SDK (Gemini).
         Source: https://github.com/googleapis/dotnet-genai (prefix reserved on NuGet).
         Model name is configurable in appsettings.json → Gemini:Model so no code
         change is needed when Google deprecates a model version. -->
    <PackageReference Include="Google.GenAI" Version="1.10.0" />
  </ItemGroup>

</Project>
